{
  "name": "dealspot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:test": "tsx src/db/test-connection.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "22.15.21",
    "@types/pg": "^8.20.0",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.6",
    "autoprefixer": "10.4.21",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.26.0",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.0",
    "typescript": "5.8.3"
  }
}
